# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="file:./gamehub.db"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate SESSION_SECRET with: openssl rand -base64 32
SESSION_SECRET="change_me_32_chars_minimum"
ADMIN_PASSWORD="change_me_strong_password"

# Public IP for admin access from outside (optional — if set, users from this IP get admin access)
# PUBLIC_IP="your.public.ip.address"

# ── Public URL (no trailing slash) ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── S3 / MinIO storage (optional — can also be set in Admin → Settings) ─────────
# Internal endpoint used by the backend (Node.js / Docker network)
# S3_ENDPOINT_INTERNO="http://minio:9000"
# Public endpoint used by the browser to display images
# S3_ENDPOINT_PUBLICO="https://s3.yourdomain.com"
# S3_BUCKET_NAME="gamehub"
# S3_ACCESS_KEY="your_access_key"
# S3_SECRET_KEY="your_secret_key"
# S3_REGION="us-east-1"    # change if MinIO returns region mismatch (e.g. eu-oest-1)

# ── API keys (optional — can also be set in Admin → Settings) ─────────────────
# RAWG metadata enrichment (https://rawg.io/apidocs)
# RAWG_API_KEY=""

# YouTube trailer search (https://console.cloud.google.com → YouTube Data API v3)
# YOUTUBE_API_KEY=""

# SteamGridDB cover art (https://www.steamgriddb.com/profile/preferences/api)
# STEAMGRIDDB_API_KEY=""

# ── Metrics (Prometheus) ───────────────────────────────────────────────────────
# /api/metrics is LAN-only by default. Set a token to allow remote scraping
# (use Prometheus `bearer_token`). See docs/observability/metrics-grafana.md
# METRICS_TOKEN=""
