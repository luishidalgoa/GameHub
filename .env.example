# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="file:./gamehub.db"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate SESSION_SECRET with: openssl rand -base64 32
SESSION_SECRET="change_me_32_chars_minimum"
ADMIN_PASSWORD="change_me_strong_password"

# Public IP for admin access from outside (optional — if set, users from this IP get admin access)
# PUBLIC_IP="your.public.ip.address"

# ── Public URL (no trailing slash) ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── API keys (optional — can also be set in Admin → Settings) ─────────────────
# RAWG metadata enrichment (https://rawg.io/apidocs)
# RAWG_API_KEY=""

# YouTube trailer search (https://console.cloud.google.com → YouTube Data API v3)
# YOUTUBE_API_KEY=""

# SteamGridDB cover art (https://www.steamgriddb.com/profile/preferences/api)
# STEAMGRIDDB_API_KEY=""
